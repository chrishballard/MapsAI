generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- Auth Models ---

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String
  role         String    @default("member")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// --- GBP Models ---

model GoogleAccount {
  id           String    @id @default(cuid())
  googleEmail  String    @unique
  accessToken  String
  refreshToken String
  tokenExpiry  DateTime
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  profiles     Profile[]
}

model Profile {
  id              String         @id @default(cuid())
  googleAccountId String
  googleAccount   GoogleAccount  @relation(fields: [googleAccountId], references: [id], onDelete: Cascade)
  locationName         String
  accountResourceName  String?
  name                 String
  placeId         String?
  address         String?
  phone           String?
  category        String?
  websiteUrl      String?
  isConnected     Boolean        @default(true)
  isOnboarded     Boolean        @default(false)
  autoApproveReviews Boolean     @default(false)
  postFrequency      Int         @default(4)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  posts           Post[]
  promptTemplate  PromptTemplate?
  reviews         Review[]
  dailyMetrics    DailyMetric[]
  monthlyKeywords MonthlyKeyword[]
  reports         Report[]
  onboardingProgress OnboardingProgress?
  keywords           ProfileKeyword[]
  cities             ProfileCity[]
  descriptions       ProfileDescription[]
  services           ProfileService[]

  @@unique([googleAccountId, locationName])
}

// --- Post Models ---

enum PostStatus {
  DRAFT
  APPROVED
  SCHEDULED
  PUBLISHED
  FAILED
}

enum PostType {
  WHATS_NEW
  EVENT
  OFFER
}

model Post {
  id           String     @id @default(cuid())
  profileId    String
  profile      Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)
  type         PostType   @default(WHATS_NEW)
  content      String
  callToAction String?
  mediaUrl     String?
  status       PostStatus @default(DRAFT)
  scheduledAt  DateTime?
  publishedAt  DateTime?
  googlePostId String?
  errorMessage String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([profileId, status])
  @@index([status, scheduledAt])
}

model PromptTemplate {
  id        String   @id @default(cuid())
  profileId String?  @unique
  profile   Profile? @relation(fields: [profileId], references: [id], onDelete: Cascade)
  category  String?
  name      String
  prompt    String   @db.Text
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([category, isDefault])
}

// --- Review Models ---

enum ReviewResponseStatus {
  PENDING
  DRAFTED
  APPROVED
  PUBLISHED
  FAILED
  SKIPPED
}

model Review {
  id             String          @id @default(cuid())
  profileId      String
  profile        Profile         @relation(fields: [profileId], references: [id], onDelete: Cascade)
  googleReviewId String          @unique
  reviewerName   String?
  rating         Int
  comment        String?
  reviewDate     DateTime
  repliedExternally Boolean      @default(false)
  response       ReviewResponse?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([profileId, repliedExternally])
}

model ReviewResponse {
  id        String               @id @default(cuid())
  reviewId  String               @unique
  review    Review               @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  content   String
  status    ReviewResponseStatus @default(DRAFTED)
  publishedAt DateTime?
  errorMessage String?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
}

// --- Analytics Models ---

model DailyMetric {
  id                      String   @id @default(cuid())
  profileId               String
  profile                 Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  date                    DateTime @db.Date
  impressionsSearchDesktop Int     @default(0)
  impressionsSearchMobile  Int     @default(0)
  impressionsMapsDesktop   Int     @default(0)
  impressionsMapsMobile    Int     @default(0)
  websiteClicks           Int      @default(0)
  callClicks              Int      @default(0)
  directionRequests       Int      @default(0)
  conversations           Int      @default(0)
  createdAt               DateTime @default(now())

  @@unique([profileId, date])
}

model MonthlyKeyword {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  month     DateTime @db.Date
  keyword   String
  impressions Int    @default(0)
  createdAt DateTime @default(now())

  @@unique([profileId, month, keyword])
}

model Report {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  month     DateTime @db.Date
  filePath  String?
  createdAt DateTime @default(now())
}

// --- Onboarding & Optimization Models ---

model OnboardingProgress {
  id              String    @id @default(cuid())
  profileId       String    @unique
  profile         Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  currentStep     Int       @default(0)
  completedSteps  Int[]     @default([])
  isComplete      Boolean   @default(false)
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model ProfileKeyword {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  keyword   String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([profileId, keyword])
}

model ProfileCity {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  city      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([profileId, city])
}

model ProfileDescription {
  id          String    @id @default(cuid())
  profileId   String
  profile     Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  content     String    @db.Text
  isApproved  Boolean   @default(false)
  isPushed    Boolean   @default(false)
  pushedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([profileId, isApproved])
}

model ProfileService {
  id              String    @id @default(cuid())
  profileId       String
  profile         Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  serviceName     String
  description     String?   @db.Text
  isStructured    Boolean   @default(true)
  isApproved      Boolean   @default(false)
  isPushed        Boolean   @default(false)
  pushedAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([profileId, serviceName])
}
